# ============================================================================
# Fantasy Agent — environment configuration
# Copy to `.env` and fill in values. Never commit `.env`.
# ============================================================================

# ----------------------------------------------------------------------------
# Core
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fantasy_agent
OAUTH_BASE_URL=https://your-public-host # public HTTPS URL for Yahoo OAuth callbacks

# ----------------------------------------------------------------------------
# ngrok tunnel (required for the default self-hosted Docker stack)
# `uv run gordie init` can configure this with your free ngrok dev domain.
# Get your authtoken at https://dashboard.ngrok.com/get-started/your-authtoken.
# The Docker connector sends traffic to http://server:8000.
# ----------------------------------------------------------------------------
NGROK_AUTHTOKEN=

# ----------------------------------------------------------------------------
# LLM (at minimum one provider key required)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai                     # openai | anthropic
LLM_MODEL=gpt-4o-mini                   # provider-specific model name

# ----------------------------------------------------------------------------
# Yahoo Fantasy (required for any fantasy functionality)
# Register an app at https://developer.yahoo.com/apps/
# ----------------------------------------------------------------------------
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# Chat media
# ----------------------------------------------------------------------------
CHAT_MEDIA=                             # comma-separated; telegram, discord, email, sms

# ----------------------------------------------------------------------------
# Telegram (optional; only needed when CHAT_MEDIA includes telegram)
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# ----------------------------------------------------------------------------
# Discord (optional; only needed when CHAT_MEDIA includes discord)
# ----------------------------------------------------------------------------
DISCORD_MODE=gateway                   # gateway for local bot websocket; interactions for public HTTPS endpoint
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=                    # interactions mode only
DISCORD_BOT_TOKEN=                     # gateway mode only
DISCORD_ALLOWED_USER_IDS=              # gateway mode only; comma-separated Discord user IDs
DISCORD_REQUIRE_MENTION=true           # gateway mode only; ignored in direct messages

# ----------------------------------------------------------------------------
# Email — Mailgun (optional; server runs without it but cannot send email)
# ----------------------------------------------------------------------------
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=                     # e.g. "Gordie <gordie@yourdomain.com>"
MAILGUN_WEBHOOK_SIGNING_KEY=

# ----------------------------------------------------------------------------
# SMS — Sinch (optional; SMS features disable if missing)
# ----------------------------------------------------------------------------
SINCH_SERVICE_PLAN_ID=
SINCH_API_TOKEN=
SINCH_FROM_NUMBER=
SINCH_WEBHOOK_TOKEN=

# ----------------------------------------------------------------------------
# Billing — Creem (optional; only needed for paid tiers)
# ----------------------------------------------------------------------------
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_API_BASE_URL=https://test-api.creem.io/v1
CREEM_PRODUCT_HOSTED_MONTHLY=

# ----------------------------------------------------------------------------
# Frontend deployment (optional)
# ----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=

# ----------------------------------------------------------------------------
# Behavior
# ----------------------------------------------------------------------------
ENABLED_SPORTS=nhl,mlb                  # comma-separated; nhl, mlb

# ----------------------------------------------------------------------------
# Frontend (SvelteKit, set in frontend/.env or via Cloudflare Pages env)
# ----------------------------------------------------------------------------
# VITE_API_URL=http://localhost:8000
# VITE_SITE_URL=http://localhost:5173
